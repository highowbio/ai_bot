# Telegram bot token from @BotFather
BOT_TOKEN=

# Comma-separated list of Telegram user IDs with admin rights
ADMIN_IDS=6903588929,6734219400

# Optional: path to persistence file (defaults to ./bot_persistence.pickle)
# PERSISTENCE_FILE=bot_persistence.pickle

# Optional: path to whitelist file (defaults to ./whitelist.json)
# WHITELIST_FILE=whitelist.json

# Optional: max file size in megabytes (defaults to 20)
# MAX_FILE_SIZE_MB=20

# Optional: log level (DEBUG, INFO, WARNING, ERROR). Defaults to INFO.
# LOG_LEVEL=INFO
