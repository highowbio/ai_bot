# Copy this to backend/runtime.env (or backend/.env) and fill in the values.
BOT_TOKEN=123456:ABC-your-token-here

# Telegram IDs of administrators, comma-separated.
BOT_ADMIN_IDS=

# Mini App URL (HTTPS) — also used for /start button and for CORS.
FRONTEND_URL=
BOT_WEBAPP_URL=
CORS_ORIGINS=

# Where whitelist.json is persisted. On Fly.io this is the /data volume.
DATA_DIR=/data

# Set RUN_BOT=0 to disable Telegram polling (API-only mode).
# RUN_BOT=1

# Seconds before initData is considered expired.
# INIT_DATA_TTL=86400

# Upload size limit in bytes.
# MAX_FILE_SIZE=20971520
